---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  preloadBodoni?: boolean;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'SCENIC STAYS',
  description = 'Luxury vacation rentals on the Florida Gulf Coast.',
  preloadBodoni = true,
  canonical,
  jsonLd,
} = Astro.props;

const schemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {
      preloadBodoni && (
        <link
          rel="preload"
          href="/fonts/bodoni-moda-latin.woff2"
          as="font"
          type="font/woff2"
          crossorigin
        />
      )
    }
    <title>{title}</title>
    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body>
    <a class="skip-link type-label-caps" href="#main">Skip to content</a>
    <svg class="grain-defs" aria-hidden="true" focusable="false">
      <filter id="grain-filter" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.85"
          numOctaves="2"
          stitchTiles="stitch"
          result="noise"></feTurbulence>
        <feColorMatrix type="saturate" values="0" in="noise" result="mono"></feColorMatrix>
      </filter>
    </svg>
    <slot />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: var(--margin-mobile);
    top: 0;
    z-index: 100;
    padding: 0.75rem 1rem;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    transform: translateY(-120%);
  }

  .skip-link:focus {
    transform: translateY(0.75rem);
    outline: var(--hairline) solid var(--gold);
    outline-offset: 3px;
  }
</style>
