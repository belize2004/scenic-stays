---
import BaseLayout from './BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import Colophon from '../components/Colophon.astro';

interface Props {
  title?: string;
  description?: string;
  active?: 'rentals' | 'guides' | 'deals' | 'management' | 'real-estate' | null;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  robots?: string;
}

const { title, description, active = null, canonical, jsonLd, robots } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  robots={robots}
>
  <Masthead active={active} />
  <slot />
  <Colophon />
</BaseLayout>
