---
/**
 * Global masthead + dual mega-nav — DNA §7–§8.
 * Vacation Rentals (4 cols) + Guides (3 cols). Hover intent, click, Escape, focus trap Tab.
 * Sticky frosted-vellum. Active underline is state-only. Mobile = full-screen paper overlay.
 */
import { site, resorts } from '../data/site';

interface Props {
  active?: 'rentals' | 'guides' | 'deals' | 'management' | 'real-estate' | null;
}

const { active = null } = Astro.props;

const primaryNav = [
  { id: 'rentals', label: 'Vacation Rentals', href: '/rentals', mega: 'rentals' as const },
  { id: 'guides', label: 'Guides', href: '/journal', mega: 'guides' as const },
  { id: 'deals', label: 'Vacation Deals', href: '/offers', mega: null },
  { id: 'management', label: 'Property Management', href: '/management', mega: null },
  { id: 'real-estate', label: 'Real Estate', href: '/real-estate', mega: null },
];

const destinations = [
  { label: '30A', href: '/rentals/30a' },
  { label: 'Destin', href: '/rentals/destin' },
  { label: 'Navarre Beach', href: '/rentals/navarre' },
  { label: 'Okaloosa Island', href: '/rentals/okaloosa-island' },
  { label: 'Panama City Beach', href: '/rentals/panama-city-beach' },
];

const collections = [
  { label: 'Gulf Front Homes', href: '/rentals/collections/gulf-front' },
  { label: 'Private Pools', href: '/rentals/collections/private-pools' },
  { label: 'Pet Friendly', href: '/rentals/collections/pet-friendly' },
  { label: 'Golf Cart Included', href: '/rentals/collections/golf-cart' },
  { label: 'The 100 Collection', href: '/rentals/collections/100' },
];

const indexLinks = [
  { label: 'A–Z Property List', href: '/rentals/a-z' },
  { label: 'All Properties', href: '/rentals' },
];

const guideDestinations = [
  { label: '30A', href: '/journal/guides/30a' },
  { label: 'Destin', href: '/journal/guides/destin' },
  { label: 'Navarre Beach', href: '/journal/guides/navarre' },
  { label: 'Panama City Beach', href: '/journal/guides/panama-city-beach' },
];

const guideStories = [
  { label: 'Destination Guides', href: '/journal/guides' },
  { label: 'Things To Do', href: '/journal/things-to-do' },
  { label: 'Weddings & Events', href: '/journal/weddings' },
  { label: 'The Journal', href: '/journal' },
];
---

<header class="masthead" data-masthead>
  <div class="masthead__bar">
    <a class="masthead__wordmark type-headline-md" href="/">{site.brand}</a>

    <nav class="masthead__nav" aria-label="Primary">
      <ul class="masthead__list">
        {
          primaryNav.map((item) => (
            <li class="masthead__item" data-nav-item={item.id}>
              {item.mega ? (
                <button
                  type="button"
                  class:list={['masthead__link type-label-caps', active === item.id && 'is-active']}
                  data-mega-trigger={item.mega}
                  aria-expanded="false"
                  aria-controls={`mega-panel-${item.mega}`}
                  id={`mega-trigger-${item.mega}`}
                >
                  {item.label}
                </button>
              ) : (
                <a
                  class:list={['masthead__link type-label-caps', active === item.id && 'is-active']}
                  href={item.href}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <a class="masthead__phone type-label-caps" href={site.phoneHref}>{site.phone}</a>

    <button
      type="button"
      class="masthead__menu-toggle type-label-caps"
      data-mobile-toggle
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      Menu
    </button>
  </div>

  {/* Vacation Rentals mega — 4 columns */}
  <div
    class="masthead__mega"
    id="mega-panel-rentals"
    data-mega-panel="rentals"
    hidden
    role="region"
    aria-labelledby="mega-trigger-rentals"
  >
    <div class="masthead__mega-grid masthead__mega-grid--4">
      <div>
        <h2 class="type-label-caps masthead__mega-heading">Destinations</h2>
        <ul class="masthead__mega-links">
          {destinations.map((l) => (
            <li>
              <a class="masthead__mega-link" href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="type-label-caps masthead__mega-heading">Resorts</h2>
        <ul class="masthead__mega-links">
          {resorts.map((l) => (
            <li>
              <a class="masthead__mega-link" href={l.href}>{l.name}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="type-label-caps masthead__mega-heading">The Collection</h2>
        <ul class="masthead__mega-links">
          {collections.map((l) => (
            <li>
              <a class="masthead__mega-link" href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div class="masthead__mega-index">
        <h2 class="type-label-caps masthead__mega-heading">Index</h2>
        <ul class="masthead__mega-links">
          {indexLinks.map((l) => (
            <li>
              <a class="masthead__mega-link" href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
        <figure class="masthead__mega-fig">
          <img
            src="/images/placeholders/mega-fig.jpg"
            alt=""
            width="96"
            height="128"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="type-label-caps">Fig. 04 — Seaside residence</figcaption>
        </figure>
      </div>
    </div>
  </div>

  {/* Guides mega — 3 columns + captioned photo */}
  <div
    class="masthead__mega"
    id="mega-panel-guides"
    data-mega-panel="guides"
    hidden
    role="region"
    aria-labelledby="mega-trigger-guides"
  >
    <div class="masthead__mega-grid masthead__mega-grid--3">
      <div>
        <h2 class="type-label-caps masthead__mega-heading">Destination Guides</h2>
        <ul class="masthead__mega-links">
          {guideDestinations.map((l) => (
            <li>
              <a class="masthead__mega-link" href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="type-label-caps masthead__mega-heading">In the Journal</h2>
        <ul class="masthead__mega-links">
          {guideStories.map((l) => (
            <li>
              <a class="masthead__mega-link" href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div class="masthead__mega-index">
        <h2 class="type-label-caps masthead__mega-heading">Featured</h2>
        <figure class="masthead__mega-fig masthead__mega-fig--wide">
          <img
            src="/images/placeholders/film-30a.jpg"
            alt=""
            width="240"
            height="160"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="type-label-caps">Fig. 12 — 30A, late afternoon</figcaption>
        </figure>
      </div>
    </div>
  </div>

  {/* Mobile — full-screen paper overlay, headline-md serif, hairline rows */}
  <div class="masthead__mobile" id="mobile-nav" data-mobile-nav hidden>
    <nav aria-label="Mobile">
      <ul>
        {
          primaryNav.map((item) => (
            <li>
              <a class="type-headline-md" href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a class="type-label-caps masthead__mobile-phone" href={site.phoneHref}>{site.phone}</a>
  </div>
</header>

<script>
  const root = document.querySelector('[data-masthead]');
  if (root instanceof HTMLElement) {
    const triggers = [...root.querySelectorAll('[data-mega-trigger]')];
    const panels = [...root.querySelectorAll('[data-mega-panel]')];
    const mobileToggle = root.querySelector('[data-mobile-toggle]');
    const mobileNav = root.querySelector('[data-mobile-nav]');

    let openTimer = 0;
    let closeTimer = 0;
    const OPEN_DELAY = 160;
    const CLOSE_DELAY = 280;
    let openId = null;

    function panelFor(id) {
      return root.querySelector(`[data-mega-panel="${id}"]`);
    }

    function triggerFor(id) {
      return root.querySelector(`[data-mega-trigger="${id}"]`);
    }

    function setMegaOpen(id) {
      window.clearTimeout(openTimer);
      window.clearTimeout(closeTimer);
      openId = id;
      for (const t of triggers) {
        const tid = t.getAttribute('data-mega-trigger');
        const on = tid === id;
        t.setAttribute('aria-expanded', on ? 'true' : 'false');
        t.classList.toggle('is-open', on);
      }
      for (const p of panels) {
        const pid = p.getAttribute('data-mega-panel');
        if (pid === id) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      }
      root.classList.toggle('is-mega-open', Boolean(id));
    }

    function closeMega() {
      setMegaOpen(null);
    }

    function scheduleOpen(id) {
      window.clearTimeout(closeTimer);
      openTimer = window.setTimeout(() => setMegaOpen(id), OPEN_DELAY);
    }

    function scheduleClose() {
      window.clearTimeout(openTimer);
      closeTimer = window.setTimeout(() => closeMega(), CLOSE_DELAY);
    }

    for (const t of triggers) {
      const id = t.getAttribute('data-mega-trigger');
      const panel = panelFor(id);
      t.addEventListener('click', () => {
        setMegaOpen(openId === id ? null : id);
      });
      t.addEventListener('mouseenter', () => scheduleOpen(id));
      t.addEventListener('mouseleave', scheduleClose);
      t.addEventListener('focus', () => scheduleOpen(id));
      panel?.addEventListener('mouseenter', () => window.clearTimeout(closeTimer));
      panel?.addEventListener('mouseleave', scheduleClose);
    }

    function setMobileOpen(open) {
      if (!(mobileToggle instanceof HTMLElement) || !(mobileNav instanceof HTMLElement)) return;
      mobileToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      mobileToggle.textContent = open ? 'Close' : 'Menu';
      if (open) {
        mobileNav.removeAttribute('hidden');
        root.classList.add('is-mobile-open');
        document.documentElement.classList.add('nav-lock');
      } else {
        mobileNav.setAttribute('hidden', '');
        root.classList.remove('is-mobile-open');
        document.documentElement.classList.remove('nav-lock');
      }
    }

    mobileToggle?.addEventListener('click', () => {
      const open = mobileToggle.getAttribute('aria-expanded') === 'true';
      setMobileOpen(!open);
      if (!open) closeMega();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const was = openId;
        closeMega();
        setMobileOpen(false);
        if (was) triggerFor(was)?.focus();
        else mobileToggle?.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) {
        closeMega();
        setMobileOpen(false);
      }
    });
  }
</script>

<style>
  :global(html.nav-lock) {
    overflow: hidden;
  }

  .masthead {
    position: sticky;
    top: 0;
    z-index: 50;
    /* DNA §7 — frosted vellum, not solid fill / not glass */
    background: color-mix(in srgb, var(--paper) 90%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .masthead__bar {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--gutter);
    padding: 1.35rem var(--margin-mobile);
  }

  @media (min-width: 960px) {
    .masthead__bar {
      grid-template-columns: auto 1fr auto;
      padding-left: var(--margin-desktop);
      padding-right: var(--margin-desktop);
    }
  }

  .masthead__wordmark {
    text-decoration: none;
    color: var(--ink);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .masthead__nav {
    display: none;
  }

  @media (min-width: 960px) {
    .masthead__nav {
      display: block;
      justify-self: center;
    }
  }

  .masthead__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .masthead__link {
    appearance: none;
    background: none;
    border: 0;
    border-bottom: var(--hairline) solid transparent;
    padding: 0.35rem 0;
    color: var(--ink);
    text-decoration: none;
    cursor: pointer;
  }

  /* Active = current section OR open panel — never a permanent decoration */
  .masthead__link.is-active,
  .masthead__link.is-open,
  .masthead__link[aria-expanded='true'] {
    border-bottom-color: var(--ink);
  }

  .masthead__phone {
    display: none;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.72;
  }

  @media (min-width: 960px) {
    .masthead__phone {
      display: inline;
    }
  }

  .masthead__menu-toggle {
    justify-self: end;
    appearance: none;
    background: none;
    border: 0;
    border-bottom: var(--hairline) solid var(--ink);
    padding: 0.35rem 0;
    color: var(--ink);
    cursor: pointer;
  }

  @media (min-width: 960px) {
    .masthead__menu-toggle {
      display: none;
    }
  }

  .masthead__mega {
    border-top: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
    background: var(--paper);
    padding: var(--stack-md) var(--margin-mobile) var(--stack-lg);
  }

  @media (min-width: 960px) {
    .masthead__mega {
      padding-left: var(--margin-desktop);
      padding-right: var(--margin-desktop);
    }
  }

  .masthead__mega-grid {
    display: grid;
    gap: var(--gutter);
  }

  @media (min-width: 960px) {
    .masthead__mega-grid--4 {
      grid-template-columns: repeat(4, 1fr);
    }
    .masthead__mega-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .masthead__mega-heading {
    margin: 0 0 1.25rem;
    opacity: 0.55;
  }

  .masthead__mega-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .masthead__mega-link {
    font-family: var(--family-display);
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: var(--weight-display);
    font-variation-settings: 'opsz' var(--opsz-display);
    line-height: 1.15;
    color: var(--ink);
    text-decoration: none;
  }

  .masthead__mega-index {
    display: flex;
    flex-direction: column;
  }

  .masthead__mega-fig {
    margin: 2rem 0 0;
  }

  .masthead__mega-fig img {
    display: block;
    width: 6rem;
    height: 8rem;
    object-fit: cover;
    margin-bottom: 0.5rem;
  }

  .masthead__mega-fig--wide img {
    width: 100%;
    max-width: 16rem;
    height: 10rem;
  }

  /* Full-screen paper overlay — not a drawer */
  .masthead__mobile {
    position: fixed;
    inset: 0;
    top: 0;
    z-index: 60;
    background: var(--paper);
    padding: 5.5rem var(--margin-mobile) var(--stack-lg);
    display: flex;
    flex-direction: column;
  }

  .masthead__mobile[hidden] {
    display: none;
  }

  .masthead.is-mobile-open .masthead__menu-toggle {
    position: relative;
    z-index: 70;
  }

  .masthead__mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .masthead__mobile li {
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .masthead__mobile a {
    display: block;
    color: var(--ink);
    text-decoration: none;
    padding: 1.25rem 0;
  }

  .masthead__mobile-phone {
    display: inline-block;
    margin-top: auto;
    padding-top: var(--stack-md);
    opacity: 0.72;
  }
</style>
