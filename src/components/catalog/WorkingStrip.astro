---
import FilterChip from './FilterChip.astro';

interface Chip {
  id: string;
  label: string;
}

interface Props {
  chips: readonly Chip[];
  activeId?: string;
  basePath: string;
  resultCount: number;
  resultNoun?: string;
  sortLabel?: string;
}

const {
  chips,
  activeId = 'all',
  basePath,
  resultCount,
  resultNoun = 'homes',
  sortLabel = 'Featured',
} = Astro.props;

const countLabel = `${resultCount} ${resultNoun}`;
---

<div class="working">
  <div class="working__inner">
    <div class="working__meta">
      <p class="type-label-caps working__count">{countLabel}</p>
      <div class="working__sort">
        <label class="type-label-caps" for="catalog-sort">Sort:</label>
        <select id="catalog-sort" class="working__sort-control type-label-caps" name="sort">
          <option selected>{sortLabel}</option>
          <option>Rate · low to high</option>
          <option>Rate · high to low</option>
          <option>Sleeps</option>
        </select>
      </div>
    </div>
    <div class="working__chips" role="list">
      {
        chips.map((c) => (
          <FilterChip
            label={c.label}
            active={c.id === activeId}
            href={c.id === 'all' ? basePath : `${basePath}?filter=${c.id}`}
          />
        ))
      }
    </div>
  </div>
</div>

<style>
  .working {
    position: sticky;
    top: 4.5rem;
    z-index: 20;
    background: color-mix(in srgb, var(--vellum) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .working__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem var(--margin-mobile);
  }

  @media (min-width: 768px) {
    .working__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding-inline: var(--margin-desktop);
    }
  }

  .working__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1.5rem;
  }

  .working__count {
    margin: 0;
  }

  .working__sort {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .working__sort label {
    opacity: 0.55;
  }

  /* Underlined text control — semantically a select, visually typeset */
  .working__sort-control {
    appearance: none;
    border: 0;
    border-bottom: var(--hairline) solid var(--ink);
    border-radius: 0;
    background: transparent;
    color: var(--ink);
    padding: 0.15rem 0;
    cursor: pointer;
  }

  .working__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
