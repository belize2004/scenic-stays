---
import FilterChip from './FilterChip.astro';

interface Chip {
  id: string;
  label: string;
}

interface Props {
  chips: readonly Chip[];
  activeId?: string;
  basePath: string;
}

const { chips, activeId = 'all', basePath } = Astro.props;
---

<div class="working">
  <div class="working__inner">
    <p class="type-label-caps working__label">Filter the collection</p>
    <div class="working__chips">
      {
        chips.map((c) => (
          <FilterChip
            label={c.label}
            active={c.id === activeId}
            href={c.id === 'all' ? basePath : `${basePath}?filter=${c.id}`}
          />
        ))
      }
    </div>
  </div>
</div>

<style>
  .working {
    position: sticky;
    top: 4.5rem;
    z-index: 20;
    background: color-mix(in srgb, var(--vellum) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .working__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem var(--margin-mobile);
  }

  @media (min-width: 768px) {
    .working__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding-inline: var(--margin-desktop);
    }
  }

  .working__label {
    margin: 0;
    opacity: 0.55;
  }

  .working__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
