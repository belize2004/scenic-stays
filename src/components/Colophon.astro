---
/**
 * Global colophon (footer) — real contact data from src/data/site.ts only.
 * Never copy confabulated addresses/phones from Stitch mocks.
 */
import { site } from '../data/site';

const rentalLinks = [
  { label: 'All Properties', href: '/rentals' },
  { label: 'Area Guides', href: '/journal' },
  { label: "What's Included", href: '/whats-included' },
  { label: 'A–Z Property List', href: '/rentals/a-z' },
  { label: 'Rental Policies', href: '/policies' },
];

const companyLinks = [
  { label: 'About Scenic Stays', href: '/about' },
  { label: 'The Journal', href: '/journal' },
  { label: 'Careers', href: '/careers' },
  { label: 'Contact', href: '/contact' },
  { label: 'FAQs', href: '/faqs' },
];

const ownerLinks = [
  { label: 'Property Management', href: '/management' },
  { label: 'Real Estate', href: '/real-estate' },
  { label: 'Owner Log In', href: 'https://scenicstays.com', external: true },
];

const socials = [
  { label: 'Instagram', href: 'https://instagram.com' },
  { label: 'Facebook', href: 'https://facebook.com' },
  { label: 'TikTok', href: 'https://tiktok.com' },
  { label: 'LinkedIn', href: 'https://linkedin.com' },
];
---

<footer class="colophon">
  <div class="colophon__inner">
    <div class="colophon__top">
      <div class="colophon__brand">
        <p class="colophon__wordmark type-headline-md">{site.brand}</p>
        <p class="type-label-caps colophon__meta">{site.addressInline}</p>
        <p class="type-label-caps colophon__meta">
          <a href={site.phoneHref}>{site.phone}</a>
        </p>
        <p class="type-label-caps colophon__email">
          <a href={site.emailHref}>{site.email}</a>
        </p>
      </div>

      <div class="colophon__columns">
        <div>
          <h2 class="type-label-caps colophon__heading">Vacation Rentals</h2>
          <ul>
            {
              rentalLinks.map((l) => (
                <li>
                  <a class="type-label-caps" href={l.href}>
                    {l.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="type-label-caps colophon__heading">Company</h2>
          <ul>
            {
              companyLinks.map((l) => (
                <li>
                  <a class="type-label-caps" href={l.href}>
                    {l.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="type-label-caps colophon__heading">Owners</h2>
          <ul>
            {
              ownerLinks.map((l) => (
                <li>
                  <a
                    class="type-label-caps"
                    href={l.href}
                    {...(l.external ? { rel: 'noopener noreferrer', target: '_blank' } : {})}
                  >
                    {l.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="colophon__newsletter">
      <p class="type-label-caps">Newsletter — your email, once a season</p>
      <form class="colophon__form" action="#" method="post">
        <label class="sr-only" for="newsletter-email">Email</label>
        <input
          id="newsletter-email"
          class="colophon__input"
          type="email"
          name="email"
          placeholder="your@email.com"
          autocomplete="email"
          required
        />
      </form>
    </div>

    <div class="colophon__bottom">
      <div class="colophon__socials">
        {
          socials.map((s) => (
            <a class="type-label-caps" href={s.href} rel="noopener noreferrer" target="_blank">
              {s.label}
            </a>
          ))
        }
      </div>
      <p class="type-label-caps colophon__legal">
        © {site.copyrightYear} {site.brand} · <a href="/privacy">Privacy</a> · <a href="/terms"
          >Terms</a
        >
      </p>
    </div>
  </div>
</footer>

<style>
  .colophon {
    background: var(--vellum);
    border-top: var(--hairline) solid var(--ink);
    color: var(--ink);
  }

  .colophon__inner {
    padding: var(--stack-lg) var(--margin-mobile) var(--stack-md);
  }

  @media (min-width: 768px) {
    .colophon__inner {
      padding-left: var(--margin-desktop);
      padding-right: var(--margin-desktop);
    }
  }

  .colophon__top {
    display: grid;
    gap: var(--stack-lg);
  }

  @media (min-width: 960px) {
    .colophon__top {
      grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
      gap: var(--gutter);
    }
  }

  .colophon__wordmark {
    letter-spacing: 0.18em;
    margin: 0 0 1.5rem;
  }

  .colophon__meta {
    margin: 0 0 0.5rem;
    opacity: 0.72;
  }

  .colophon__meta a,
  .colophon__email a,
  .colophon__legal a,
  .colophon__columns a,
  .colophon__socials a {
    color: inherit;
    text-decoration: none;
  }

  .colophon__email {
    margin: 0.75rem 0 0;
    color: var(--gold);
  }

  .colophon__columns {
    display: grid;
    gap: var(--stack-md);
  }

  @media (min-width: 640px) {
    .colophon__columns {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .colophon__heading {
    margin: 0 0 1.25rem;
  }

  .colophon__columns ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .colophon__columns a {
    opacity: 0.72;
  }

  .colophon__columns a:hover {
    opacity: 1;
  }

  .colophon__newsletter {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: var(--stack-lg);
    padding: var(--stack-md) 0;
    border-top: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  @media (min-width: 768px) {
    .colophon__newsletter {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .colophon__form {
    width: 100%;
    max-width: 28rem;
  }

  .colophon__input {
    width: 100%;
    border: 0;
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--ink) 35%, transparent);
    background: transparent;
    color: var(--ink);
    font-family: var(--family-display);
    font-size: clamp(18px, 2vw, 22px);
    font-style: italic;
    font-weight: var(--weight-display);
    font-variation-settings: 'opsz' var(--opsz-display);
    padding: 0.5rem 0;
    border-radius: 0;
  }

  .colophon__input::placeholder {
    color: color-mix(in srgb, var(--ink) 35%, transparent);
  }

  .colophon__bottom {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: var(--stack-md);
  }

  @media (min-width: 768px) {
    .colophon__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .colophon__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem;
  }

  .colophon__socials a,
  .colophon__legal {
    opacity: 0.72;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
