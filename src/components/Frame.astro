---
/**
 * Viewport frame — DNA §5.
 * Height uses svh only (never vh). Quiet frames are still composed viewports.
 * Catalog register bodies opt out with flow={true}.
 * Use min-height only — never fixed height — so content is never clipped.
 */
interface Props {
  variant?: 'loud' | 'quiet';
  /** Pixels of the next section visible at the bottom. Loud default: 50. Quiet default: 0. */
  peek?: number;
  background?: 'paper' | 'vellum';
  /**
   * Opt out of viewport framing (catalog register: listing bodies, tables, review rows).
   * Quiet ≠ flow. Quiet is the rest-beat frame and still gets min-height.
   */
  flow?: boolean;
  class?: string;
  as?: 'section' | 'div' | 'header' | 'footer';
}

const {
  variant = 'quiet',
  peek = variant === 'loud' ? 50 : 0,
  background = 'paper',
  flow = false,
  class: className = '',
  as: Tag = 'section',
} = Astro.props;

const bg = background === 'vellum' ? 'var(--vellum)' : 'var(--paper)';

const style: Record<string, string> = {
  backgroundColor: bg,
};

if (!flow) {
  const frameHeight = peek > 0 ? `calc(100svh - ${peek}px)` : '100svh';
  style.minHeight = frameHeight;
}
---

<Tag
  class:list={['frame', `frame--${variant}`, flow && 'frame--flow', className]}
  data-variant={variant}
  data-background={background}
  data-peek={String(peek)}
  data-flow={flow ? 'true' : 'false'}
  style={style}
>
  {variant === 'quiet' && !flow && <div class="frame__hairline" aria-hidden="true" />}
  <div class="frame__inner">
    <slot />
  </div>
</Tag>

<style>
  .frame {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  .frame__hairline {
    position: absolute;
    top: 0;
    left: var(--margin-mobile);
    right: var(--margin-mobile);
    height: var(--hairline);
    background-color: var(--ink);
    opacity: 0.2;
  }

  @media (min-width: 768px) {
    .frame__hairline {
      left: var(--margin-desktop);
      right: var(--margin-desktop);
    }
  }

  .frame__inner {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    width: 100%;
  }
</style>
