---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Frame from '../../components/Frame.astro';
import EditorialHero from '../../components/EditorialHero.astro';
import WorkingStrip from '../../components/catalog/WorkingStrip.astro';
import PropertyRow from '../../components/catalog/PropertyRow.astro';
import Pagination from '../../components/catalog/Pagination.astro';
import { destinations, listings, filterChips } from '../../content/listings';

export function getStaticPaths() {
  return Object.keys(destinations).map((slug) => ({ params: { destination: slug } }));
}

const { destination } = Astro.params;
const dest = destinations[destination as keyof typeof destinations];

if (!dest) {
  return Astro.redirect('/rentals');
}

const results = listings.filter((l) => l.destination === dest.slug);
const page = 1;
const totalPages = 8;
---

<SiteLayout
  title={`${dest.name.replace(/\.$/, '')} | SCENIC STAYS`}
  description={dest.dek}
  active="rentals"
>
  <main id="main">
    <Frame variant="loud" background="paper" minHeight="70svh" class="dest-cover">
      <div class="dest-cover__inner">
        <EditorialHero
          image={dest.image}
          alt={dest.alt}
          headline={dest.name}
          polarity={dest.polarity}
          scrimStrength={dest.scrimStrength}
          caption={dest.caption}
          coordinate={dest.coordinate}
        />
        <p class="type-headline-md dest-cover__dek">{dest.dek}</p>
      </div>
    </Frame>

    <Frame variant="quiet" background="paper" flow>
      <div class="dest-prose">
        <p class="type-body-lg">{dest.prose}</p>
      </div>
    </Frame>

    <WorkingStrip chips={filterChips} basePath={`/rentals/${dest.slug}`} />

    <Frame variant="quiet" background="paper" flow>
      <div class="dest-results">
        {
          results.map((l, i) => (
            <PropertyRow
              name={l.name}
              whisper={l.whisper}
              prose={l.prose}
              rateFrom={l.rateFrom}
              href={`/rentals/${l.slug}`}
              image={l.image}
              alt={l.alt}
              photoSide={i % 2 === 0 ? 'left' : 'right'}
            />
          ))
        }
      </div>
      <Pagination page={page} totalPages={totalPages} nextHref={`/rentals/${dest.slug}?page=2`} />
    </Frame>

    <Frame variant="quiet" background="vellum">
      <div class="dest-close">
        <p class="type-headline-lg"><em>The harbor awaits.</em></p>
        <a class="btn-ghost" href="/rentals">View all properties</a>
      </div>
    </Frame>
  </main>
</SiteLayout>

<style>
  .dest-cover__inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 70svh;
    position: relative;
  }

  .dest-cover__dek {
    position: relative;
    z-index: 2;
    text-align: center;
    margin: -2rem auto var(--stack-md);
    max-width: 28ch;
    padding-inline: var(--margin-mobile);
  }

  .dest-prose {
    padding: var(--stack-md) var(--margin-mobile);
    max-width: 42rem;
  }

  @media (min-width: 768px) {
    .dest-prose {
      padding-inline: var(--margin-desktop);
    }
  }

  .dest-results {
    border-top: var(--hairline) solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .dest-close {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stack-md);
    text-align: center;
    padding: var(--stack-xl) var(--margin-mobile);
  }
</style>
