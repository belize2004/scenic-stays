---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="SCENIC STAYS | The Emerald Coast, properly.">
  <main style="padding: var(--stack-lg) var(--margin-mobile);">
    <p class="type-label-caps">SCENIC STAYS</p>
    <h1 class="type-display-xl" style="max-width: 12ch; margin-top: var(--stack-md);">
      The Emerald Coast, <em>properly</em>.
    </h1>
    <p class="type-body-lg" style="margin-top: var(--stack-md); max-width: 36rem;">
      Foundation in progress. Review the
      <a class="link-gold" href="/style-guide">style guide</a>.
    </p>
  </main>
</BaseLayout>
